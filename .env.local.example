# Google Gemini (free tier — get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Site URL (update after deploying)
NEXT_PUBLIC_SITE_URL=https://eminmeme.vercel.app

# Umami Analytics (get from https://cloud.umami.is)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id_here
